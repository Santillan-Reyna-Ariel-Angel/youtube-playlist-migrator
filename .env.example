GOOGLE_CLIENT_ID=tu_client_id
GOOGLE_CLIENT_SECRET=tu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# Opcionales: si los dejás vacíos, el script los guarda automáticamente
# en .youtube-refresh-tokens.json la primera vez que autorizás cada cuenta.
SOURCE_REFRESH_TOKEN=
DEST_REFRESH_TOKEN=

SOURCE_PLAYLIST_ID=
DEST_PLAYLIST_TITLE=Mi Playlist Migrada
DEST_PRIVACY_STATUS=private
